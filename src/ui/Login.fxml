<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ui.librarian.NavigationController"
      prefWidth="1180" prefHeight="760" styleClass="login-root">
    <VBox alignment="CENTER_LEFT" spacing="24" prefWidth="520" styleClass="login-brand-panel">
        <HBox alignment="CENTER_LEFT" spacing="12">
            <StackPane styleClass="login-brand-mark"><Label text="L" styleClass="login-brand-mark-text" /></StackPane>
            <VBox spacing="1"><Label text="Libris" styleClass="login-brand-name" /><Label text="LIBRARY MANAGEMENT SYSTEM" styleClass="login-brand-caption" /></VBox>
        </HBox>
        <Pane VBox.vgrow="ALWAYS" />
        <VBox spacing="12">
            <Label text="Manage your library with confidence." wrapText="true" styleClass="login-message" />
            <Label text="Books, members, borrowing records, holds, and fines—all in one organized system." wrapText="true" styleClass="login-message-detail" />
        </VBox>
        <Pane VBox.vgrow="ALWAYS" />
        <Label text="CSC 4350 · Team 7" styleClass="login-footer" />
    </VBox>

    <StackPane HBox.hgrow="ALWAYS" styleClass="login-form-panel">
        <VBox spacing="22" maxWidth="390" styleClass="login-form">
            <VBox spacing="6"><Label text="Welcome back" styleClass="login-title" /><Label text="Sign in to continue to the library system." styleClass="login-subtitle" /></VBox>
            <VBox spacing="8"><Label text="Email address" styleClass="login-field-label" /><TextField fx:id="loginEmail" promptText="Enter your email" styleClass="login-field" /></VBox>
            <VBox spacing="8"><HBox alignment="CENTER_LEFT"><Label text="Password" styleClass="login-field-label" HBox.hgrow="ALWAYS" /><Button text="Forgot password?" styleClass="login-link" onAction="#showPlaceholder" /></HBox><PasswordField fx:id="loginPassword" promptText="Enter your password" styleClass="login-field" onAction="#signIn" /></VBox>
            <Label fx:id="loginError" visible="false" managed="false" wrapText="true" styleClass="login-error" />
            <HBox alignment="CENTER_LEFT" spacing="8"><CheckBox /><Label text="Keep me signed in" styleClass="remember-label" /></HBox>
            <Button text="Sign in" maxWidth="Infinity" styleClass="login-button" onAction="#signIn" />
            <VBox spacing="5" styleClass="demo-accounts">
                <Label text="DEMO ACCOUNTS" styleClass="demo-title" />
                <TextField text="Librarian: librarian@library.org / library123" editable="false" styleClass="demo-credential" />
                <TextField text="Member: member@library.org / member123" editable="false" styleClass="demo-credential" />
            </VBox>
            <HBox alignment="CENTER" spacing="5"><Label text="Need help signing in?" styleClass="login-help-text" /><Button text="Contact support" styleClass="login-link" onAction="#showPlaceholder" /></HBox>
        </VBox>
    </StackPane>
</HBox>
