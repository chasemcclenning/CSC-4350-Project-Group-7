<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    prefWidth="900"
    prefHeight="600">

    <top>
        <VBox alignment="CENTER" spacing="8" style="-fx-padding: 30 20 20 20;">
            <Label text="Library Management System"
                   style="-fx-font-size: 32px; -fx-font-weight: bold;" />
            <Label text="Main Dashboard"
                   style="-fx-font-size: 16px; -fx-text-fill: #555555;" />
        </VBox>
    </top>

    <center>
        <GridPane alignment="CENTER" hgap="20" vgap="20">

            <Button text="Search Books" prefWidth="220" prefHeight="70"
                    GridPane.columnIndex="0" GridPane.rowIndex="0" />

            <Button text="Borrow / Return" prefWidth="220" prefHeight="70"
                    GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Button text="Manage Books" prefWidth="220" prefHeight="70"
                    GridPane.columnIndex="0" GridPane.rowIndex="1" />

            <Button text="Checkout Records" prefWidth="220" prefHeight="70"
                    GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Button text="Members" prefWidth="220" prefHeight="70"
                    GridPane.columnIndex="0" GridPane.rowIndex="2" />

            <Button text="Holds" prefWidth="220" prefHeight="70"
                    GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Button text="Fines" prefWidth="220" prefHeight="70"
                    GridPane.columnIndex="0" GridPane.rowIndex="3" />

            <Button text="Audit Log" prefWidth="220" prefHeight="70"
                    GridPane.columnIndex="1" GridPane.rowIndex="3" />

        </GridPane>
    </center>

    <bottom>
        <VBox alignment="CENTER" style="-fx-padding: 20;">
            <Button text="Logout" prefWidth="180" prefHeight="45" />
        </VBox>
    </bottom>

</BorderPane>
