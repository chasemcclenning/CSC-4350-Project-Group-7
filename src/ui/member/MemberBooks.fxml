<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?><?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.member.MemberBooksController" prefWidth="1180" prefHeight="760" styleClass="member-root">
<top><HBox alignment="CENTER_LEFT" spacing="10" styleClass="member-header"><Label text="L" styleClass="member-brand-mark" /><Label text="Libris" styleClass="member-brand" HBox.hgrow="ALWAYS" /><Button text="Home" styleClass="member-nav" onAction="#showMemberHome" /><Button text="Browse" styleClass="member-nav" onAction="#showMemberCatalog" /><Button text="My Books" styleClass="member-nav-active" onAction="#showMemberBooks" /><Button text="My Account" styleClass="member-nav" onAction="#showMemberAccount" /><Button text="Account" styleClass="member-profile-button" onAction="#showMemberAccount" /></HBox></top>
<center><ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="member-scroll"><content><VBox spacing="20" styleClass="member-content"><VBox spacing="4"><Label text="My Books" styleClass="member-page-title" /><Label text="Your borrowing information from the library database." styleClass="member-page-subtitle" /></VBox><VBox spacing="12" styleClass="member-card"><HBox><Label text="Current loans" styleClass="member-section-title" HBox.hgrow="ALWAYS" /><Button text="Borrow another book" styleClass="member-secondary" onAction="#showMemberCatalog" /></HBox><VBox fx:id="currentLoans" spacing="10" /></VBox><VBox spacing="12" styleClass="member-card"><Label text="Borrowing history" styleClass="member-section-title" /><VBox fx:id="borrowingHistory" spacing="10" /></VBox></VBox></content></ScrollPane></center></BorderPane>
