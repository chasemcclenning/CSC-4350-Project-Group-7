<?xml version="1.0" encoding="UTF-8"?><?import javafx.scene.control.*?><?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.member.MemberAccountController" prefWidth="1180" prefHeight="760" styleClass="member-root"><top><HBox alignment="CENTER_LEFT" spacing="10" styleClass="member-header"><Label text="L" styleClass="member-brand-mark"/><Label text="Libris" styleClass="member-brand" HBox.hgrow="ALWAYS"/><Button text="Home" styleClass="member-nav" onAction="#showMemberHome"/><Button text="Browse" styleClass="member-nav" onAction="#showMemberCatalog"/><Button text="My Books" styleClass="member-nav" onAction="#showMemberBooks"/><Button text="My Account" styleClass="member-nav-active" onAction="#showMemberAccount"/></HBox></top><center><ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="member-scroll"><content><VBox spacing="18" styleClass="member-content"><HBox><VBox HBox.hgrow="ALWAYS"><Label text="My Account" styleClass="member-page-title"/><Label text="Your SQL account, holds, and fines." styleClass="member-page-subtitle"/></VBox><Button text="Sign out" styleClass="member-secondary" onAction="#showLogin"/></HBox><HBox spacing="18"><VBox spacing="14" styleClass="member-card" HBox.hgrow="ALWAYS"><Label text="Profile" styleClass="member-section-title"/><HBox spacing="12"><VBox HBox.hgrow="ALWAYS"><Label text="Name"/><TextField fx:id="accountName" styleClass="account-field"/></VBox><VBox HBox.hgrow="ALWAYS"><Label text="Member ID"/><TextField fx:id="accountId" editable="false" styleClass="account-field"/></VBox></HBox><Label text="Email"/><TextField fx:id="accountEmail" styleClass="account-field"/><Button text="Save profile" styleClass="member-primary" onAction="#saveProfile"/></VBox><VBox spacing="12" prefWidth="300" styleClass="member-card"><Label text="Account status" styleClass="member-section-title"/><HBox><Label text="Membership" HBox.hgrow="ALWAYS"/><Label fx:id="accountStatus" text="Not signed in"/></HBox><HBox><Label text="Outstanding fines" HBox.hgrow="ALWAYS"/><Label fx:id="accountFines" text="\$0.00"/></HBox><HBox><Label text="Active checkouts" HBox.hgrow="ALWAYS"/><Label fx:id="accountCheckouts" text="0"/></HBox></VBox></HBox><HBox spacing="18"><VBox spacing="10" styleClass="member-card" HBox.hgrow="ALWAYS"><Label text="My Holds" styleClass="member-section-title"/><VBox fx:id="holdsList" spacing="10"/></VBox><VBox spacing="10" prefWidth="350" styleClass="member-card"><Label text="Fine history" styleClass="member-section-title"/><VBox fx:id="finesList" spacing="10"/></VBox></HBox></VBox></content></ScrollPane></center></BorderPane>
