<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ui.librarian.NavigationController" prefWidth="1440" prefHeight="900" styleClass="root-pane">
    <left>
        <VBox prefWidth="248" styleClass="sidebar">
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="brand-block"><StackPane styleClass="brand-mark"><Label text="L" styleClass="brand-mark-text" /></StackPane><VBox spacing="1"><Label text="Libris" styleClass="brand-title" /><Label text="LIBRARIAN PORTAL" styleClass="brand-caption" /></VBox></HBox>
            <Label text="WORKSPACE" styleClass="nav-section-label" />
            <VBox spacing="6" styleClass="nav-list"><Button text="⌂   Dashboard" maxWidth="Infinity" styleClass="nav-button" onAction="#showDashboard" /><Button text="▤   Books" maxWidth="Infinity" styleClass="nav-button" onAction="#showBooks" /><Button text="♙   Members" maxWidth="Infinity" styleClass="nav-button" onAction="#showMembers" /><Button text="⇄   Borrow &amp; Return" maxWidth="Infinity" styleClass="nav-button" onAction="#showBorrowReturn" /><Button text="◷   Holds" maxWidth="Infinity" styleClass="nav-button" onAction="#showHolds" /><Button text="\$   Fines" maxWidth="Infinity" styleClass="nav-button" onAction="#showFines" /></VBox>
            <Label text="MANAGEMENT" styleClass="nav-section-label" />
            <VBox spacing="6" styleClass="nav-list"><Button text="▦   Audit Log" maxWidth="Infinity" styleClass="nav-button" onAction="#showAuditLog" /><Button text="▥   Reports" maxWidth="Infinity" styleClass="nav-button" onAction="#showReports" /><Button text="⚙   Settings" maxWidth="Infinity" styleClass="nav-active" onAction="#showSettings" /></VBox>
            <Pane VBox.vgrow="ALWAYS" />
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-profile"><StackPane styleClass="avatar-small"><Label text="AO" styleClass="avatar-text" /></StackPane><VBox spacing="2" HBox.hgrow="ALWAYS"><Label text="Alex Owens" styleClass="profile-name" /><Label text="Librarian" styleClass="profile-role" /></VBox><Button text="↪" styleClass="icon-button-quiet" onAction="#showLogin" /></HBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="22" styleClass="settings-content">
            <VBox spacing="4"><Label text="Settings" styleClass="page-title" /><Label text="Manage your library preferences and account." styleClass="page-subtitle" /></VBox>

            <HBox spacing="18" VBox.vgrow="ALWAYS">
                <VBox spacing="6" prefWidth="220" styleClass="settings-menu">
                    <Label text="SETTINGS" styleClass="settings-menu-label" />
                    <Button fx:id="generalSettingsButton" text="General" maxWidth="Infinity" styleClass="settings-menu-active" onAction="#showGeneralSettings" />
                    <Button fx:id="accountSettingsButton" text="Account" maxWidth="Infinity" styleClass="settings-menu-button" onAction="#showAccountSettings" />
                    <Button fx:id="circulationSettingsButton" text="Circulation" maxWidth="Infinity" styleClass="settings-menu-button" onAction="#showCirculationSettings" />
                    <Button fx:id="notificationSettingsButton" text="Notifications" maxWidth="Infinity" styleClass="settings-menu-button" onAction="#showNotificationSettings" />
                    <Button fx:id="backupSettingsButton" text="Backup" maxWidth="Infinity" styleClass="settings-menu-button" onAction="#showBackupSettings" />
                    <Pane VBox.vgrow="ALWAYS" />
                    <VBox spacing="5" styleClass="settings-help">
                        <Label text="Need help?" styleClass="help-title" />
                        <Label text="Review the project documentation for configuration details." wrapText="true" styleClass="help-text" />
                        <Button text="View documentation" styleClass="help-button" onAction="#showPlaceholder" />
                    </VBox>
                </VBox>

                <StackPane HBox.hgrow="ALWAYS">
                <ScrollPane fx:id="generalSettingsPage" fitToWidth="true" hbarPolicy="NEVER" styleClass="settings-scroll">
                    <content>
                        <VBox spacing="16" styleClass="settings-form">
                            <VBox spacing="4">
                                <Label text="General settings" styleClass="settings-title" />
                                <Label text="Basic information and default library behavior." styleClass="section-subtitle" />
                            </VBox>

                            <VBox spacing="14" styleClass="settings-section">
                                <VBox spacing="3"><Label text="Library information" styleClass="settings-section-title" /><Label text="Shown throughout the librarian portal" styleClass="section-subtitle" /></VBox>
                                <HBox spacing="14">
                                    <VBox spacing="7" HBox.hgrow="ALWAYS"><Label text="Library name" styleClass="field-label" /><TextField text="Libris Library" styleClass="settings-field" /></VBox>
                                    <VBox spacing="7" HBox.hgrow="ALWAYS"><Label text="Contact email" styleClass="field-label" /><TextField text="contact@library.org" styleClass="settings-field" /></VBox>
                                </HBox>
                            </VBox>

                            <VBox spacing="14" styleClass="settings-section">
                                <VBox spacing="3"><Label text="Circulation defaults" styleClass="settings-section-title" /><Label text="Applied when creating checkouts and holds" styleClass="section-subtitle" /></VBox>
                                <HBox spacing="14">
                                    <VBox spacing="7" HBox.hgrow="ALWAYS"><Label text="Loan period" styleClass="field-label" /><ComboBox promptText="14 days" maxWidth="Infinity" styleClass="settings-field" /></VBox>
                                    <VBox spacing="7" HBox.hgrow="ALWAYS"><Label text="Hold expiration" styleClass="field-label" /><ComboBox promptText="7 days" maxWidth="Infinity" styleClass="settings-field" /></VBox>
                                </HBox>
                            </VBox>

                            <VBox spacing="0" styleClass="settings-section">
                                <VBox spacing="3" styleClass="notification-heading"><Label text="Notifications" styleClass="settings-section-title" /><Label text="Choose which library events create alerts" styleClass="section-subtitle" /></VBox>
                                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="preference-row"><VBox spacing="3" HBox.hgrow="ALWAYS"><Label text="Overdue books" styleClass="preference-title" /><Label text="Alert when a checkout passes its due date." styleClass="preference-detail" /></VBox><CheckBox selected="true" /></HBox>
                                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="preference-row"><VBox spacing="3" HBox.hgrow="ALWAYS"><Label text="Available holds" styleClass="preference-title" /><Label text="Alert when a requested copy becomes available." styleClass="preference-detail" /></VBox><CheckBox selected="true" /></HBox>
                            </VBox>

                            <HBox alignment="CENTER_LEFT" spacing="14" styleClass="backup-card">
                                <Label text="▣" styleClass="backup-icon" />
                                <VBox spacing="4" HBox.hgrow="ALWAYS"><Label text="Database backup" styleClass="settings-section-title" /><Label text="Last backup: July 17, 2026 at 2:00 AM" styleClass="preference-detail" /></VBox>
                                <Label text="Up to date" styleClass="backup-status" />
                                <Button text="Back up now" styleClass="secondary-button" onAction="#showPlaceholder" />
                            </HBox>

                            <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="settings-actions"><Button text="Cancel" styleClass="secondary-button" onAction="#showSettings" /><Button text="Save changes" styleClass="primary-button" onAction="#showPlaceholder" /></HBox>
                        </VBox>
                    </content>
                </ScrollPane>

                <ScrollPane fx:id="accountSettingsPage" fitToWidth="true" hbarPolicy="NEVER" visible="false" managed="false" styleClass="settings-scroll">
                    <content><VBox spacing="16" styleClass="settings-form">
                        <VBox spacing="4"><Label text="Account" styleClass="settings-title" /><Label text="Update your librarian profile and password." styleClass="section-subtitle" /></VBox>
                        <VBox spacing="14" styleClass="settings-section">
                            <VBox spacing="3"><Label text="Profile information" styleClass="settings-section-title" /><Label text="Used to identify activity recorded in the audit log" styleClass="section-subtitle" /></VBox>
                            <HBox spacing="14"><VBox spacing="7" HBox.hgrow="ALWAYS"><Label text="Display name" styleClass="field-label" /><TextField text="Alex Owens" styleClass="settings-field" /></VBox><VBox spacing="7" HBox.hgrow="ALWAYS"><Label text="Email address" styleClass="field-label" /><TextField text="alex.owens@library.org" styleClass="settings-field" /></VBox></HBox>
                            <VBox spacing="7"><Label text="User ID" styleClass="field-label" /><TextField text="U-10001" editable="false" styleClass="settings-field" /></VBox>
                        </VBox>
                        <VBox spacing="14" styleClass="settings-section">
                            <VBox spacing="3"><Label text="Change password" styleClass="settings-section-title" /><Label text="Confirm your current password before choosing a new one" styleClass="section-subtitle" /></VBox>
                            <VBox spacing="7"><Label text="Current password" styleClass="field-label" /><PasswordField promptText="Enter current password" styleClass="settings-field" /></VBox>
                            <HBox spacing="14"><VBox spacing="7" HBox.hgrow="ALWAYS"><Label text="New password" styleClass="field-label" /><PasswordField promptText="Enter new password" styleClass="settings-field" /></VBox><VBox spacing="7" HBox.hgrow="ALWAYS"><Label text="Confirm password" styleClass="field-label" /><PasswordField promptText="Confirm new password" styleClass="settings-field" /></VBox></HBox>
                        </VBox>
                        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="settings-actions"><Button text="Cancel" styleClass="secondary-button" onAction="#showAccountSettings" /><Button text="Save account" styleClass="primary-button" onAction="#showPlaceholder" /></HBox>
                    </VBox></content>
                </ScrollPane>

                <ScrollPane fx:id="circulationSettingsPage" fitToWidth="true" hbarPolicy="NEVER" visible="false" managed="false" styleClass="settings-scroll">
                    <content><VBox spacing="16" styleClass="settings-form">
                        <VBox spacing="4"><Label text="Circulation" styleClass="settings-title" /><Label text="Configure checkout, return, hold, and fine defaults." styleClass="section-subtitle" /></VBox>
                        <VBox spacing="14" styleClass="settings-section">
                            <VBox spacing="3"><Label text="Checkout rules" styleClass="settings-section-title" /><Label text="Defaults applied to new borrowing records" styleClass="section-subtitle" /></VBox>
                            <HBox spacing="14"><VBox spacing="7" HBox.hgrow="ALWAYS"><Label text="Default loan period" styleClass="field-label" /><ComboBox promptText="14 days" maxWidth="Infinity" styleClass="settings-field" /></VBox><VBox spacing="7" HBox.hgrow="ALWAYS"><Label text="Maximum active checkouts" styleClass="field-label" /><TextField text="5" styleClass="settings-field" /></VBox></HBox>
                            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="preference-row"><VBox spacing="3" HBox.hgrow="ALWAYS"><Label text="Block checkout when fines are owed" styleClass="preference-title" /><Label text="Members must resolve unpaid fines before borrowing." styleClass="preference-detail" /></VBox><CheckBox selected="true" /></HBox>
                        </VBox>
                        <VBox spacing="14" styleClass="settings-section">
                            <VBox spacing="3"><Label text="Hold rules" styleClass="settings-section-title" /></VBox>
                            <HBox spacing="14"><VBox spacing="7" HBox.hgrow="ALWAYS"><Label text="Hold expiration period" styleClass="field-label" /><ComboBox promptText="7 days" maxWidth="Infinity" styleClass="settings-field" /></VBox><VBox spacing="7" HBox.hgrow="ALWAYS"><Label text="Maximum active holds" styleClass="field-label" /><TextField text="3" styleClass="settings-field" /></VBox></HBox>
                        </VBox>
                        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="settings-actions"><Button text="Reset defaults" styleClass="secondary-button" onAction="#showCirculationSettings" /><Button text="Save circulation" styleClass="primary-button" onAction="#showPlaceholder" /></HBox>
                    </VBox></content>
                </ScrollPane>

                <ScrollPane fx:id="notificationSettingsPage" fitToWidth="true" hbarPolicy="NEVER" visible="false" managed="false" styleClass="settings-scroll">
                    <content><VBox spacing="16" styleClass="settings-form">
                        <VBox spacing="4"><Label text="Notifications" styleClass="settings-title" /><Label text="Choose which events appear as librarian alerts." styleClass="section-subtitle" /></VBox>
                        <VBox spacing="0" styleClass="settings-section">
                            <VBox spacing="3" styleClass="notification-heading"><Label text="Circulation alerts" styleClass="settings-section-title" /></VBox>
                            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="preference-row"><VBox spacing="3" HBox.hgrow="ALWAYS"><Label text="Overdue checkout" styleClass="preference-title" /><Label text="Alert when a book passes its due date." styleClass="preference-detail" /></VBox><CheckBox selected="true" /></HBox>
                            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="preference-row"><VBox spacing="3" HBox.hgrow="ALWAYS"><Label text="Hold available" styleClass="preference-title" /><Label text="Alert when a held copy becomes available." styleClass="preference-detail" /></VBox><CheckBox selected="true" /></HBox>
                            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="preference-row"><VBox spacing="3" HBox.hgrow="ALWAYS"><Label text="Hold expiring" styleClass="preference-title" /><Label text="Alert one day before an active hold expires." styleClass="preference-detail" /></VBox><CheckBox selected="true" /></HBox>
                            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="preference-row"><VBox spacing="3" HBox.hgrow="ALWAYS"><Label text="Fine created" styleClass="preference-title" /><Label text="Alert when a new fine is added to a member." styleClass="preference-detail" /></VBox><CheckBox selected="false" /></HBox>
                        </VBox>
                        <HBox alignment="CENTER_RIGHT" spacing="10" styleClass="settings-actions"><Button text="Disable all" styleClass="secondary-button" onAction="#showNotificationSettings" /><Button text="Save notifications" styleClass="primary-button" onAction="#showPlaceholder" /></HBox>
                    </VBox></content>
                </ScrollPane>

                <ScrollPane fx:id="backupSettingsPage" fitToWidth="true" hbarPolicy="NEVER" visible="false" managed="false" styleClass="settings-scroll">
                    <content><VBox spacing="16" styleClass="settings-form">
                        <VBox spacing="4"><Label text="Backup" styleClass="settings-title" /><Label text="Protect the library database from data loss." styleClass="section-subtitle" /></VBox>
                        <HBox alignment="CENTER_LEFT" spacing="14" styleClass="backup-card"><Label text="▣" styleClass="backup-icon" /><VBox spacing="4" HBox.hgrow="ALWAYS"><Label text="Database is protected" styleClass="settings-section-title" /><Label text="Last successful backup: July 17, 2026 at 2:00 AM" styleClass="preference-detail" /></VBox><Label text="Up to date" styleClass="backup-status" /></HBox>
                        <VBox spacing="14" styleClass="settings-section">
                            <VBox spacing="3"><Label text="Automatic backup" styleClass="settings-section-title" /><Label text="Create a scheduled copy of stored library data" styleClass="section-subtitle" /></VBox>
                            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="preference-row"><VBox spacing="3" HBox.hgrow="ALWAYS"><Label text="Enable automatic backups" styleClass="preference-title" /><Label text="Recommended for reliability." styleClass="preference-detail" /></VBox><CheckBox selected="true" /></HBox>
                            <HBox spacing="14"><VBox spacing="7" HBox.hgrow="ALWAYS"><Label text="Frequency" styleClass="field-label" /><ComboBox promptText="Daily" maxWidth="Infinity" styleClass="settings-field" /></VBox><VBox spacing="7" HBox.hgrow="ALWAYS"><Label text="Backup time" styleClass="field-label" /><TextField text="2:00 AM" styleClass="settings-field" /></VBox></HBox>
                        </VBox>
                        <VBox spacing="12" styleClass="settings-section"><Label text="Manual backup" styleClass="settings-section-title" /><Label text="Create a backup immediately before large updates or maintenance." styleClass="preference-detail" /><HBox spacing="10"><Button text="Back up now" styleClass="primary-button" onAction="#showPlaceholder" /><Button text="Restore backup" styleClass="secondary-button" onAction="#showPlaceholder" /></HBox></VBox>
                        <HBox alignment="CENTER_RIGHT"><Button text="Save backup settings" styleClass="primary-button" onAction="#showPlaceholder" /></HBox>
                    </VBox></content>
                </ScrollPane>
                </StackPane>
            </HBox>
        </VBox>
    </center>
</BorderPane>
