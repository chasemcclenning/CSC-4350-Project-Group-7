<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ui.librarian.NavigationController" prefWidth="1440" prefHeight="900" styleClass="root-pane">
    <left>
        <VBox prefWidth="248" styleClass="sidebar">
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="brand-block"><StackPane styleClass="brand-mark"><Label text="L" styleClass="brand-mark-text" /></StackPane><VBox spacing="1"><Label text="Libris" styleClass="brand-title" /><Label text="LIBRARIAN PORTAL" styleClass="brand-caption" /></VBox></HBox>
            <Label text="WORKSPACE" styleClass="nav-section-label" />
            <VBox spacing="6" styleClass="nav-list">
                <Button text="⌂   Dashboard" maxWidth="Infinity" styleClass="nav-button" onAction="#showDashboard" /><Button text="▤   Books" maxWidth="Infinity" styleClass="nav-button" onAction="#showBooks" /><Button text="♙   Members" maxWidth="Infinity" styleClass="nav-button" onAction="#showMembers" /><Button text="⇄   Borrow &amp; Return" maxWidth="Infinity" styleClass="nav-button" onAction="#showBorrowReturn" /><Button text="◷   Holds" maxWidth="Infinity" styleClass="nav-button" onAction="#showHolds" /><Button text="\$   Fines" maxWidth="Infinity" styleClass="nav-active" onAction="#showFines" />
            </VBox>
            <Label text="MANAGEMENT" styleClass="nav-section-label" />
            <VBox spacing="6" styleClass="nav-list"><Button text="▦   Audit Log" maxWidth="Infinity" styleClass="nav-button" onAction="#showAuditLog" /><Button text="▥   Reports" maxWidth="Infinity" styleClass="nav-button" onAction="#showReports" /><Button text="⚙   Settings" maxWidth="Infinity" styleClass="nav-button" onAction="#showSettings" /></VBox>
            <Pane VBox.vgrow="ALWAYS" />
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-profile"><StackPane styleClass="avatar-small"><Label text="AO" styleClass="avatar-text" /></StackPane><VBox spacing="2" HBox.hgrow="ALWAYS"><Label text="Alex Owens" styleClass="profile-name" /><Label text="Librarian" styleClass="profile-role" /></VBox><Button text="↪" styleClass="icon-button-quiet" onAction="#showLogin" /></HBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="22" styleClass="fines-content">
            <HBox alignment="CENTER_LEFT" spacing="16"><VBox spacing="4" HBox.hgrow="ALWAYS"><Label text="Fines" styleClass="page-title" /><Label text="Review and resolve member fines." styleClass="page-subtitle" /></VBox><Button text="+  Add fine" styleClass="primary-button" onAction="#showPlaceholder" /></HBox>
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="fines-toolbar"><TextField promptText="Search by fine, checkout, or member ID" HBox.hgrow="ALWAYS" styleClass="fines-search" /><ComboBox promptText="All statuses" prefWidth="160" styleClass="fine-filter" /><Button text="Clear filters" styleClass="toolbar-button" onAction="#showPlaceholder" /></HBox>

            <VBox spacing="0" VBox.vgrow="ALWAYS" styleClass="fines-panel">
                <HBox alignment="CENTER_LEFT" styleClass="fines-panel-header"><VBox spacing="3" HBox.hgrow="ALWAYS"><Label text="Fine records" styleClass="section-title" /><Label text="Paid, unpaid, and waived balances" styleClass="section-subtitle" /></VBox><Label text="Showing 1–5 of 84" styleClass="result-count" /></HBox>
                <GridPane styleClass="fine-table-header"><columnConstraints><ColumnConstraints percentWidth="15" /><ColumnConstraints percentWidth="18" /><ColumnConstraints percentWidth="18" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="21" /></columnConstraints><Label text="FINE ID" styleClass="column-label" GridPane.columnIndex="0" /><Label text="CHECKOUT ID" styleClass="column-label" GridPane.columnIndex="1" /><Label text="MEMBER ID" styleClass="column-label" GridPane.columnIndex="2" /><Label text="AMOUNT" styleClass="column-label" GridPane.columnIndex="3" /><Label text="STATUS" styleClass="column-label" GridPane.columnIndex="4" /><Label text="ACTIONS" styleClass="column-label" GridPane.columnIndex="5" /></GridPane>
                <VBox spacing="0" VBox.vgrow="ALWAYS">
                    <GridPane alignment="CENTER_LEFT" styleClass="fine-row"><columnConstraints><ColumnConstraints percentWidth="15" /><ColumnConstraints percentWidth="18" /><ColumnConstraints percentWidth="18" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="21" /></columnConstraints><Label text="F-2931" styleClass="fine-id" GridPane.columnIndex="0" /><Label text="C-2832" styleClass="cell-text" GridPane.columnIndex="1" /><Label text="U-10430" styleClass="cell-text" GridPane.columnIndex="2" /><Label text="\$8.50" styleClass="fine-amount" GridPane.columnIndex="3" /><Label text="Unpaid" styleClass="status-unpaid" GridPane.columnIndex="4" /><HBox spacing="6" GridPane.columnIndex="5"><Button text="Collect" styleClass="row-primary" onAction="#showPlaceholder" /><Button text="Waive" styleClass="row-action" onAction="#showPlaceholder" /></HBox></GridPane>
                    <GridPane alignment="CENTER_LEFT" styleClass="fine-row"><columnConstraints><ColumnConstraints percentWidth="15" /><ColumnConstraints percentWidth="18" /><ColumnConstraints percentWidth="18" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="21" /></columnConstraints><Label text="F-2930" styleClass="fine-id" GridPane.columnIndex="0" /><Label text="C-2827" styleClass="cell-text" GridPane.columnIndex="1" /><Label text="U-10428" styleClass="cell-text" GridPane.columnIndex="2" /><Label text="\$3.00" styleClass="fine-amount" GridPane.columnIndex="3" /><Label text="Paid" styleClass="status-paid" GridPane.columnIndex="4" /><Button text="View" styleClass="row-action" GridPane.columnIndex="5" onAction="#showPlaceholder" /></GridPane>
                    <GridPane alignment="CENTER_LEFT" styleClass="fine-row"><columnConstraints><ColumnConstraints percentWidth="15" /><ColumnConstraints percentWidth="18" /><ColumnConstraints percentWidth="18" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="21" /></columnConstraints><Label text="F-2929" styleClass="fine-id" GridPane.columnIndex="0" /><Label text="C-2822" styleClass="cell-text" GridPane.columnIndex="1" /><Label text="U-10431" styleClass="cell-text" GridPane.columnIndex="2" /><Label text="\$12.00" styleClass="fine-amount" GridPane.columnIndex="3" /><Label text="Waived" styleClass="status-waived" GridPane.columnIndex="4" /><Button text="View" styleClass="row-action" GridPane.columnIndex="5" onAction="#showPlaceholder" /></GridPane>
                    <GridPane alignment="CENTER_LEFT" styleClass="fine-row"><columnConstraints><ColumnConstraints percentWidth="15" /><ColumnConstraints percentWidth="18" /><ColumnConstraints percentWidth="18" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="21" /></columnConstraints><Label text="F-2928" styleClass="fine-id" GridPane.columnIndex="0" /><Label text="C-2816" styleClass="cell-text" GridPane.columnIndex="1" /><Label text="U-10432" styleClass="cell-text" GridPane.columnIndex="2" /><Label text="\$5.50" styleClass="fine-amount" GridPane.columnIndex="3" /><Label text="Unpaid" styleClass="status-unpaid" GridPane.columnIndex="4" /><HBox spacing="6" GridPane.columnIndex="5"><Button text="Collect" styleClass="row-primary" onAction="#showPlaceholder" /><Button text="Waive" styleClass="row-action" onAction="#showPlaceholder" /></HBox></GridPane>
                    <GridPane alignment="CENTER_LEFT" styleClass="fine-row, fine-row-last"><columnConstraints><ColumnConstraints percentWidth="15" /><ColumnConstraints percentWidth="18" /><ColumnConstraints percentWidth="18" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="21" /></columnConstraints><Label text="F-2927" styleClass="fine-id" GridPane.columnIndex="0" /><Label text="C-2811" styleClass="cell-text" GridPane.columnIndex="1" /><Label text="U-10429" styleClass="cell-text" GridPane.columnIndex="2" /><Label text="\$2.00" styleClass="fine-amount" GridPane.columnIndex="3" /><Label text="Paid" styleClass="status-paid" GridPane.columnIndex="4" /><Button text="View" styleClass="row-action" GridPane.columnIndex="5" onAction="#showPlaceholder" /></GridPane>
                </VBox>
                <HBox alignment="CENTER_RIGHT" spacing="6" styleClass="pagination"><Button text="←" styleClass="page-button" onAction="#showPlaceholder" /><Button text="1" styleClass="page-button-active" onAction="#showPlaceholder" /><Button text="2" styleClass="page-button" onAction="#showPlaceholder" /><Button text="3" styleClass="page-button" onAction="#showPlaceholder" /><Button text="→" styleClass="page-button" onAction="#showPlaceholder" /></HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
