<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?><?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.librarian.MemberManagementController" prefWidth="1440" prefHeight="900" styleClass="root-pane">
<left><VBox prefWidth="248" styleClass="sidebar"><HBox alignment="CENTER_LEFT" spacing="12" styleClass="brand-block"><StackPane styleClass="brand-mark"><Label text="L" styleClass="brand-mark-text" /></StackPane><VBox spacing="1"><Label text="Libris" styleClass="brand-title" /><Label text="LIBRARIAN PORTAL" styleClass="brand-caption" /></VBox></HBox><Label text="WORKSPACE" styleClass="nav-section-label" /><VBox spacing="6" styleClass="nav-list"><Button text="⌂   Dashboard" maxWidth="Infinity" styleClass="nav-button" onAction="#showDashboard" /><Button text="▤   Books" maxWidth="Infinity" styleClass="nav-button" onAction="#showBooks" /><Button text="♙   Members" maxWidth="Infinity" styleClass="nav-active" onAction="#showMembers" /><Button text="⇄   Borrow &amp; Return" maxWidth="Infinity" styleClass="nav-button" onAction="#showBorrowReturn" /><Button text="◷   Holds" maxWidth="Infinity" styleClass="nav-button" onAction="#showHolds" /><Button text="\$   Fines" maxWidth="Infinity" styleClass="nav-button" onAction="#showFines" /></VBox><Label text="MANAGEMENT" styleClass="nav-section-label" /><VBox spacing="6" styleClass="nav-list"><Button text="▦   Audit Log" maxWidth="Infinity" styleClass="nav-button" onAction="#showAuditLog" /><Button text="▥   Reports" maxWidth="Infinity" styleClass="nav-button" onAction="#showReports" /><Button text="⚙   Settings" maxWidth="Infinity" styleClass="nav-button" onAction="#showSettings" /></VBox><Pane VBox.vgrow="ALWAYS" /><HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-profile"><StackPane styleClass="avatar-small"><Label fx:id="sidebarProfileInitials" text="CR" styleClass="avatar-text" /></StackPane><VBox spacing="2" HBox.hgrow="ALWAYS"><Label fx:id="sidebarProfileName" text="Signed-in librarian" styleClass="profile-name" /><Label text="Librarian" styleClass="profile-role" /></VBox><Button text="↪" styleClass="icon-button-quiet" onAction="#showLogin" /></HBox></VBox></left>
<center><VBox spacing="22" styleClass="members-content"><HBox alignment="CENTER_LEFT"><VBox spacing="4" HBox.hgrow="ALWAYS"><Label text="Accounts" styleClass="page-title" /><Label text="View and manage member and librarian accounts." styleClass="page-subtitle" /></VBox><Button text="+  Add account" styleClass="primary-button" onAction="#addMember" /></HBox><HBox spacing="12" styleClass="members-toolbar"><TextField fx:id="memberSearch" promptText="Search by name or email" HBox.hgrow="ALWAYS" styleClass="members-search" onAction="#refresh" /><ComboBox fx:id="accountFilter" prefWidth="160" styleClass="member-filter" onAction="#refresh" /><Button text="Clear filters" styleClass="toolbar-button" onAction="#clearFilters" /></HBox><VBox spacing="12" VBox.vgrow="ALWAYS" styleClass="members-panel"><HBox alignment="CENTER_LEFT"><Label text="Account directory" styleClass="section-title" HBox.hgrow="ALWAYS" /><Label fx:id="memberCount" styleClass="result-count" /></HBox><TableView fx:id="memberTable" VBox.vgrow="ALWAYS"><columns><TableColumn fx:id="memberColumn" text="Name" prefWidth="220" /><TableColumn fx:id="emailColumn" text="Email" prefWidth="280" /><TableColumn fx:id="statusColumn" text="Account" prefWidth="160" /><TableColumn fx:id="finesColumn" text="Fines owed" prefWidth="120" /></columns><placeholder><Label text="No accounts match the selected filters." /></placeholder></TableView><HBox alignment="CENTER_RIGHT" spacing="8"><Button text="Refresh" styleClass="row-action" onAction="#refresh" /><Button text="View selected" styleClass="row-action" onAction="#viewMember" /><Button text="Edit selected" styleClass="row-action" onAction="#editMember" /><Button text="Delete selected" styleClass="row-delete" onAction="#deleteMember" /></HBox></VBox></VBox></center></BorderPane>
