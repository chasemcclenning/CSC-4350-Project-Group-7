<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?><?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.librarian.BookCatalogController" prefWidth="1440" prefHeight="900" styleClass="root-pane">
<left><VBox prefWidth="248" styleClass="sidebar"><HBox alignment="CENTER_LEFT" spacing="12" styleClass="brand-block"><StackPane styleClass="brand-mark"><Label text="L" styleClass="brand-mark-text" /></StackPane><VBox spacing="1"><Label text="Libris" styleClass="brand-title" /><Label text="LIBRARIAN PORTAL" styleClass="brand-caption" /></VBox></HBox><Label text="WORKSPACE" styleClass="nav-section-label" /><VBox spacing="6" styleClass="nav-list"><Button text="⌂   Dashboard" maxWidth="Infinity" styleClass="nav-button" onAction="#showDashboard" /><Button text="▤   Books" maxWidth="Infinity" styleClass="nav-active" onAction="#showBooks" /><Button text="♙   Members" maxWidth="Infinity" styleClass="nav-button" onAction="#showMembers" /><Button text="⇄   Borrow &amp; Return" maxWidth="Infinity" styleClass="nav-button" onAction="#showBorrowReturn" /><Button text="◷   Holds" maxWidth="Infinity" styleClass="nav-button" onAction="#showHolds" /><Button text="\$   Fines" maxWidth="Infinity" styleClass="nav-button" onAction="#showFines" /></VBox><Label text="MANAGEMENT" styleClass="nav-section-label" /><VBox spacing="6" styleClass="nav-list"><Button text="▦   Audit Log" maxWidth="Infinity" styleClass="nav-button" onAction="#showAuditLog" /><Button text="▥   Reports" maxWidth="Infinity" styleClass="nav-button" onAction="#showReports" /><Button text="⚙   Settings" maxWidth="Infinity" styleClass="nav-button" onAction="#showSettings" /></VBox><Pane VBox.vgrow="ALWAYS" /><HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-profile"><StackPane styleClass="avatar-small"><Label fx:id="sidebarProfileInitials" text="CR" styleClass="avatar-text" /></StackPane><VBox spacing="2" HBox.hgrow="ALWAYS"><Label fx:id="sidebarProfileName" text="Signed-in librarian" styleClass="profile-name" /><Label text="Librarian" styleClass="profile-role" /></VBox><Button text="↪" styleClass="icon-button-quiet" onAction="#showLogin" /></HBox></VBox></left>
<center><VBox spacing="22" styleClass="catalog-content"><HBox alignment="CENTER_LEFT"><VBox spacing="4" HBox.hgrow="ALWAYS"><Label text="Books" styleClass="page-title" /><Label text="Search and manage the live library catalog." styleClass="page-subtitle" /></VBox><Button text="+  Add book" styleClass="primary-button" onAction="#addBook" /></HBox><HBox spacing="12" styleClass="catalog-toolbar"><TextField fx:id="bookSearch" promptText="Search by title or author" HBox.hgrow="ALWAYS" styleClass="catalog-search" onAction="#refresh" /><ComboBox fx:id="genreFilter" prefWidth="150" styleClass="filter-control" onAction="#refresh" /><ComboBox fx:id="availabilityFilter" prefWidth="170" styleClass="filter-control" onAction="#refresh" /><Button text="Clear filters" styleClass="toolbar-button" onAction="#clearFilters" /></HBox><VBox spacing="12" VBox.vgrow="ALWAYS" styleClass="catalog-panel"><HBox alignment="CENTER_LEFT"><Label text="Book inventory" styleClass="section-title" HBox.hgrow="ALWAYS" /><Label fx:id="bookCount" styleClass="result-count" /></HBox><TableView fx:id="bookTable" VBox.vgrow="ALWAYS"><columns><TableColumn fx:id="titleColumn" text="Title" prefWidth="230" /><TableColumn fx:id="authorColumn" text="Author" prefWidth="160" /><TableColumn fx:id="genreColumn" text="Genre" prefWidth="120" /><TableColumn fx:id="isbnColumn" text="ISBN" prefWidth="160" /><TableColumn fx:id="copiesColumn" text="Total copies" prefWidth="95" /><TableColumn fx:id="statusColumn" text="Available copies" prefWidth="150" /></columns><placeholder><Label text="No books match the selected filters." /></placeholder></TableView><HBox alignment="CENTER_RIGHT" spacing="8"><Button text="Refresh" styleClass="row-action" onAction="#refresh" /><Button text="View profile" styleClass="row-action" onAction="#viewBook" /><Button text="Edit selected" styleClass="row-action" onAction="#editBook" /><Button text="Delete selected" styleClass="row-delete" onAction="#deleteBook" /></HBox></VBox></VBox></center></BorderPane>
