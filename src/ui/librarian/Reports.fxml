<?xml version="1.0" encoding="UTF-8"?><?import javafx.scene.control.*?><?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.librarian.ReportsController" prefWidth="1440" prefHeight="900" styleClass="root-pane"><left><VBox prefWidth="248" styleClass="sidebar"><HBox alignment="CENTER_LEFT" spacing="12" styleClass="brand-block"><StackPane styleClass="brand-mark"><Label text="L" styleClass="brand-mark-text"/></StackPane><Label text="Libris" styleClass="brand-title"/></HBox><Label text="WORKSPACE" styleClass="nav-section-label"/><VBox spacing="6" styleClass="nav-list"><Button text="⌂   Dashboard" maxWidth="Infinity" styleClass="nav-button" onAction="#showDashboard"/><Button text="▤   Books" maxWidth="Infinity" styleClass="nav-button" onAction="#showBooks"/><Button text="♙   Members" maxWidth="Infinity" styleClass="nav-button" onAction="#showMembers"/><Button text="⇄   Borrow &amp; Return" maxWidth="Infinity" styleClass="nav-button" onAction="#showBorrowReturn"/><Button text="◷   Holds" maxWidth="Infinity" styleClass="nav-button" onAction="#showHolds"/><Button text="\$   Fines" maxWidth="Infinity" styleClass="nav-button" onAction="#showFines"/></VBox><Label text="MANAGEMENT" styleClass="nav-section-label"/><VBox spacing="6" styleClass="nav-list"><Button text="▦   Audit Log" maxWidth="Infinity" styleClass="nav-button" onAction="#showAuditLog"/><Button text="▥   Reports" maxWidth="Infinity" styleClass="nav-active" onAction="#showReports"/><Button text="⚙   Settings" maxWidth="Infinity" styleClass="nav-button" onAction="#showSettings"/></VBox><Pane VBox.vgrow="ALWAYS"/><HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-profile"><StackPane styleClass="avatar-small"><Label fx:id="sidebarProfileInitials" text="L" styleClass="avatar-text"/></StackPane><VBox spacing="2" HBox.hgrow="ALWAYS"><Label fx:id="sidebarProfileName" text="Signed-in librarian" styleClass="profile-name"/><Label text="Librarian" styleClass="profile-role"/></VBox><Button text="↪" styleClass="icon-button-quiet" onAction=