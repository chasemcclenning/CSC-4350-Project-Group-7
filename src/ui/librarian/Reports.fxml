<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ui.librarian.NavigationController" prefWidth="1440" prefHeight="900" styleClass="root-pane">
    <left>
        <VBox prefWidth="248" styleClass="sidebar">
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="brand-block"><StackPane styleClass="brand-mark"><Label text="L" styleClass="brand-mark-text" /></StackPane><VBox spacing="1"><Label text="Libris" styleClass="brand-title" /><Label text="LIBRARIAN PORTAL" styleClass="brand-caption" /></VBox></HBox>
            <Label text="WORKSPACE" styleClass="nav-section-label" />
            <VBox spacing="6" styleClass="nav-list"><Button text="⌂   Dashboard" maxWidth="Infinity" styleClass="nav-button" onAction="#showDashboard" /><Button text="▤   Books" maxWidth="Infinity" styleClass="nav-button" onAction="#showBooks" /><Button text="♙   Members" maxWidth="Infinity" styleClass="nav-button" onAction="#showMembers" /><Button text="⇄   Borrow &amp; Return" maxWidth="Infinity" styleClass="nav-button" onAction="#showBorrowReturn" /><Button text="◷   Holds" maxWidth="Infinity" styleClass="nav-button" onAction="#showHolds" /><Button text="\$   Fines" maxWidth="Infinity" styleClass="nav-button" onAction="#showFines" /></VBox>
            <Label text="MANAGEMENT" styleClass="nav-section-label" />
            <VBox spacing="6" styleClass="nav-list"><Button text="▦   Audit Log" maxWidth="Infinity" styleClass="nav-button" onAction="#showAuditLog" /><Button text="▥   Reports" maxWidth="Infinity" styleClass="nav-active" onAction="#showReports" /><Button text="⚙   Settings" maxWidth="Infinity" styleClass="nav-button" onAction="#showSettings" /></VBox>
            <Pane VBox.vgrow="ALWAYS" />
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-profile"><StackPane styleClass="avatar-small"><Label text="AO" styleClass="avatar-text" /></StackPane><VBox spacing="2" HBox.hgrow="ALWAYS"><Label text="Alex Owens" styleClass="profile-name" /><Label text="Librarian" styleClass="profile-role" /></VBox><Button text="↪" styleClass="icon-button-quiet" onAction="#showPlaceholder" /></HBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="22" styleClass="reports-content">
            <VBox spacing="4"><Label text="Reports" styleClass="page-title" /><Label text="Generate and export library records." styleClass="page-subtitle" /></VBox>

            <VBox spacing="18" styleClass="report-builder">
                <VBox spacing="3"><Label text="Create report" styleClass="section-title" /><Label text="Select the records and date range to include" styleClass="section-subtitle" /></VBox>
                <HBox spacing="14">
                    <VBox spacing="7" HBox.hgrow="ALWAYS"><Label text="Report type" styleClass="field-label" /><ComboBox promptText="Choose report type" maxWidth="Infinity" styleClass="report-field" /></VBox>
                    <VBox spacing="7" HBox.hgrow="ALWAYS"><Label text="Start date" styleClass="field-label" /><DatePicker promptText="Select date" maxWidth="Infinity" styleClass="report-field" /></VBox>
                    <VBox spacing="7" HBox.hgrow="ALWAYS"><Label text="End date" styleClass="field-label" /><DatePicker promptText="Select date" maxWidth="Infinity" styleClass="report-field" /></VBox>
                    <VBox spacing="7" HBox.hgrow="ALWAYS"><Label text="File format" styleClass="field-label" /><ComboBox promptText="PDF or CSV" maxWidth="Infinity" styleClass="report-field" /></VBox>
                </HBox>
                <HBox alignment="CENTER_RIGHT" spacing="10"><Button text="Clear" styleClass="secondary-button" onAction="#showPlaceholder" /><Button text="Generate report" styleClass="primary-button" onAction="#showPlaceholder" /></HBox>
            </VBox>

            <GridPane hgap="14" vgap="14">
                <columnConstraints><ColumnConstraints percentWidth="25" hgrow="ALWAYS" /><ColumnConstraints percentWidth="25" hgrow="ALWAYS" /><ColumnConstraints percentWidth="25" hgrow="ALWAYS" /><ColumnConstraints percentWidth="25" hgrow="ALWAYS" /></columnConstraints>
                <Button text="▤  Book inventory" maxWidth="Infinity" styleClass="report-type-card" GridPane.columnIndex="0" onAction="#showPlaceholder" />
                <Button text="⇄  Borrowing records" maxWidth="Infinity" styleClass="report-type-card" GridPane.columnIndex="1" onAction="#showPlaceholder" />
                <Button text="◷  Overdue books" maxWidth="Infinity" styleClass="report-type-card" GridPane.columnIndex="2" onAction="#showPlaceholder" />
                <Button text="\$  Fine records" maxWidth="Infinity" styleClass="report-type-card" GridPane.columnIndex="3" onAction="#showPlaceholder" />
            </GridPane>

            <VBox spacing="0" VBox.vgrow="ALWAYS" styleClass="recent-panel">
                <HBox alignment="CENTER_LEFT" styleClass="recent-header"><VBox spacing="3" HBox.hgrow="ALWAYS"><Label text="Recent reports" styleClass="section-title" /><Label text="Previously generated files" styleClass="section-subtitle" /></VBox></HBox>
                <GridPane styleClass="report-table-header"><columnConstraints><ColumnConstraints percentWidth="32" /><ColumnConstraints percentWidth="20" /><ColumnConstraints percentWidth="20" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="14" /></columnConstraints><Label text="REPORT" styleClass="column-label" GridPane.columnIndex="0" /><Label text="DATE RANGE" styleClass="column-label" GridPane.columnIndex="1" /><Label text="CREATED" styleClass="column-label" GridPane.columnIndex="2" /><Label text="FORMAT" styleClass="column-label" GridPane.columnIndex="3" /><Label text="ACTION" styleClass="column-label" GridPane.columnIndex="4" /></GridPane>
                <VBox spacing="0">
                    <GridPane styleClass="report-row"><columnConstraints><ColumnConstraints percentWidth="32" /><ColumnConstraints percentWidth="20" /><ColumnConstraints percentWidth="20" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="14" /></columnConstraints><Label text="Monthly borrowing records" styleClass="report-name" GridPane.columnIndex="0" /><Label text="Jun 1 – Jun 30" styleClass="cell-text" GridPane.columnIndex="1" /><Label text="Jul 1, 2026" styleClass="cell-text" GridPane.columnIndex="2" /><Label text="PDF" styleClass="format-badge" GridPane.columnIndex="3" /><Button text="Download" styleClass="row-action" GridPane.columnIndex="4" onAction="#showPlaceholder" /></GridPane>
                    <GridPane styleClass="report-row"><columnConstraints><ColumnConstraints percentWidth="32" /><ColumnConstraints percentWidth="20" /><ColumnConstraints percentWidth="20" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="14" /></columnConstraints><Label text="Overdue book records" styleClass="report-name" GridPane.columnIndex="0" /><Label text="Jun 1 – Jun 30" styleClass="cell-text" GridPane.columnIndex="1" /><Label text="Jul 1, 2026" styleClass="cell-text" GridPane.columnIndex="2" /><Label text="CSV" styleClass="format-badge" GridPane.columnIndex="3" /><Button text="Download" styleClass="row-action" GridPane.columnIndex="4" onAction="#showPlaceholder" /></GridPane>
                    <GridPane styleClass="report-row, report-row-last"><columnConstraints><ColumnConstraints percentWidth="32" /><ColumnConstraints percentWidth="20" /><ColumnConstraints percentWidth="20" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="14" /></columnConstraints><Label text="Book inventory" styleClass="report-name" GridPane.columnIndex="0" /><Label text="All records" styleClass="cell-text" GridPane.columnIndex="1" /><Label text="Jun 28, 2026" styleClass="cell-text" GridPane.columnIndex="2" /><Label text="PDF" styleClass="format-badge" GridPane.columnIndex="3" /><Button text="Download" styleClass="row-action" GridPane.columnIndex="4" onAction="#showPlaceholder" /></GridPane>
                </VBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
