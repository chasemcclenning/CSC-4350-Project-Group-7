<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ui.librarian.LibrarianDashboardController"
            prefWidth="1440" prefHeight="900"
            styleClass="root-pane">

    <left>
        <VBox prefWidth="248" styleClass="sidebar">
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="brand-block">
                <StackPane styleClass="brand-mark">
                    <Label text="L" styleClass="brand-mark-text" />
                </StackPane>
                <VBox spacing="1">
                    <Label text="Libris" styleClass="brand-title" />
                    <Label text="LIBRARIAN PORTAL" styleClass="brand-caption" />
                </VBox>
            </HBox>

            <Label text="WORKSPACE" styleClass="nav-section-label" />
            <VBox spacing="6" styleClass="nav-list">
                <Button text="⌂   Dashboard" maxWidth="Infinity" styleClass="nav-active" onAction="#showDashboard" />
                <Button text="▤   Books" maxWidth="Infinity" styleClass="nav-button" onAction="#showBooks" />
                <Button text="♙   Members" maxWidth="Infinity" styleClass="nav-button" onAction="#showMembers" />
                <Button text="⇄   Borrow &amp; Return" maxWidth="Infinity" styleClass="nav-button" onAction="#showBorrowReturn" />
                <Button text="◷   Holds" maxWidth="Infinity" styleClass="nav-button" onAction="#showHolds" />
                <Button text="\$   Fines" maxWidth="Infinity" styleClass="nav-button" onAction="#showFines" />
            </VBox>

            <Label text="MANAGEMENT" styleClass="nav-section-label">
                <VBox.margin><Insets top="20" /></VBox.margin>
            </Label>
            <VBox spacing="6" styleClass="nav-list">
                <Button text="▦   Audit Log" maxWidth="Infinity" styleClass="nav-button" onAction="#showAuditLog" />
                <Button text="▥   Reports" maxWidth="Infinity" styleClass="nav-button" onAction="#showReports" />
                <Button text="⚙   Settings" maxWidth="Infinity" styleClass="nav-button" onAction="#showSettings" />
            </VBox>

            <Pane VBox.vgrow="ALWAYS" />

            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-profile">
                <StackPane styleClass="avatar-small">
                    <Label fx:id="profileInitials" text="L" styleClass="avatar-text" />
                </StackPane>
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                    <Label fx:id="profileName" text="Librarian" styleClass="profile-name" />
                    <Label text="Librarian" styleClass="profile-role" />
                </VBox>
                <Button text="↪" styleClass="icon-button-quiet" onAction="#showLogin" />
            </HBox>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="dashboard-scroll">
            <content>
                <VBox spacing="24" styleClass="main-content">
                    <HBox alignment="CENTER_LEFT" spacing="18" styleClass="topbar">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label fx:id="welcomeLabel" text="Good morning" styleClass="page-title" />
                            <Label text="Here’s what’s happening in your library today." styleClass="page-subtitle" />
                        </VBox>
                        <TextField fx:id="dashboardSearch" promptText="Search books or members" prefWidth="290" styleClass="search-box" onAction="#searchDashboard" />
                        <Button text="⌕" styleClass="notification-button" onAction="#searchDashboard" />
                        <Button text="+  New checkout" styleClass="primary-button" onAction="#showBorrowReturn" />
                    </HBox>
                    <VBox fx:id="searchResults" visible="false" managed="false" spacing="6" styleClass="search-results" />

                    <GridPane hgap="16" vgap="16">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50" hgrow="ALWAYS" />
                            <ColumnConstraints percentWidth="50" hgrow="ALWAYS" />
                        </columnConstraints>

                        <VBox spacing="10" styleClass="stat-card" GridPane.columnIndex="0">
                            <HBox alignment="CENTER_LEFT">
                                <Label text="BOOKS" styleClass="stat-eyebrow" HBox.hgrow="ALWAYS" />
                                <Label text="▤" styleClass="stat-icon, stat-icon-blue" />
                            </HBox>
                            <Label fx:id="titleCount" text="0" styleClass="stat-number" />
                            <Label text="Total titles in the catalog" styleClass="stat-description" />
                        </VBox>

                        <VBox spacing="10" styleClass="stat-card" GridPane.columnIndex="1">
                            <HBox alignment="CENTER_LEFT">
                                <Label text="ACTIVE CHECKOUTS" styleClass="stat-eyebrow" HBox.hgrow="ALWAYS" />
                                <Label text="⇄" styleClass="stat-icon, stat-icon-orange" />
                            </HBox>
                            <Label fx:id="checkoutCount" text="0" styleClass="stat-number" />
                            <Label text="Books currently borrowed" styleClass="stat-description" />
                        </VBox>
                    </GridPane>

                    <HBox spacing="18">
                        <VBox spacing="18" styleClass="panel" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT">
                                <VBox spacing="3" HBox.hgrow="ALWAYS">
                                    <Label text="Recent activity" styleClass="section-title" />
                                    <Label text="Latest circulation updates" styleClass="section-subtitle" />
                                </VBox>
                                <Button text="View all  →" styleClass="text-button" onAction="#showAuditLog" />
                            </HBox>

                            <VBox fx:id="recentActivity" spacing="10">
                                <!-- Database activity is inserted by LibrarianDashboardController. -->
                            </VBox>
                        </VBox>

                        <VBox spacing="18" prefWidth="330" styleClass="panel">
                            <HBox alignment="CENTER_LEFT">
                                <VBox spacing="3" HBox.hgrow="ALWAYS">
                                    <Label text="Overdue items" styleClass="section-title" />
                                    <Label fx:id="overdueSummary" text="No overdue books." styleClass="section-subtitle" />
                                </VBox>
                                <Label fx:id="overdueCount" text="0" styleClass="alert-badge" />
                            </HBox>
                            <VBox fx:id="overdueItems" spacing="12">
                                <!-- Database overdue items are inserted by LibrarianDashboardController. -->
                            </VBox>
                            <Button text="Review overdue items" maxWidth="Infinity" styleClass="secondary-button" onAction="#showHolds" />
                        </VBox>
                    </HBox>

                    <VBox spacing="14">
                        <Label text="Quick actions" styleClass="section-title" />
                        <GridPane hgap="14" vgap="14">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="25" hgrow="ALWAYS" />
                                <ColumnConstraints percentWidth="25" hgrow="ALWAYS" />
                                <ColumnConstraints percentWidth="25" hgrow="ALWAYS" />
                                <ColumnConstraints percentWidth="25" hgrow="ALWAYS" />
                            </columnConstraints>
                            <Button text="＋  Add a book" maxWidth="Infinity" styleClass="action-card" GridPane.columnIndex="0" onAction="#showBooks" />
                            <Button text="♙  Add member" maxWidth="Infinity" styleClass="action-card" GridPane.columnIndex="1" onAction="#showMembers" />
                            <Button text="⇄  Process return" maxWidth="Infinity" styleClass="action-card" GridPane.columnIndex="2" onAction="#showBorrowReturn" />
                            <Button text="▥  Generate report" maxWidth="Infinity" styleClass="action-card" GridPane.columnIndex="3" onAction="#showReports" />
                        </GridPane>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
