<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ui.librarian.NavigationController"
            prefWidth="1440" prefHeight="900"
            styleClass="root-pane">
    <left>
        <VBox prefWidth="248" styleClass="sidebar">
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="brand-block">
                <StackPane styleClass="brand-mark"><Label text="L" styleClass="brand-mark-text" /></StackPane>
                <VBox spacing="1"><Label text="Libris" styleClass="brand-title" /><Label text="LIBRARIAN PORTAL" styleClass="brand-caption" /></VBox>
            </HBox>
            <Label text="WORKSPACE" styleClass="nav-section-label" />
            <VBox spacing="6" styleClass="nav-list">
                <Button text="⌂   Dashboard" maxWidth="Infinity" styleClass="nav-button" onAction="#showDashboard" />
                <Button text="▤   Books" maxWidth="Infinity" styleClass="nav-button" onAction="#showBooks" />
                <Button text="♙   Members" maxWidth="Infinity" styleClass="nav-button" onAction="#showMembers" />
                <Button text="⇄   Borrow &amp; Return" maxWidth="Infinity" styleClass="nav-button" onAction="#showBorrowReturn" />
                <Button text="◷   Holds" maxWidth="Infinity" styleClass="nav-active" onAction="#showHolds" />
                <Button text="\$   Fines" maxWidth="Infinity" styleClass="nav-button" onAction="#showFines" />
            </VBox>
            <Label text="MANAGEMENT" styleClass="nav-section-label" />
            <VBox spacing="6" styleClass="nav-list">
                <Button text="▦   Audit Log" maxWidth="Infinity" styleClass="nav-button" onAction="#showAuditLog" />
                <Button text="▥   Reports" maxWidth="Infinity" styleClass="nav-button" onAction="#showReports" />
                <Button text="⚙   Settings" maxWidth="Infinity" styleClass="nav-button" onAction="#showSettings" />
            </VBox>
            <Pane VBox.vgrow="ALWAYS" />
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-profile">
                <StackPane styleClass="avatar-small"><Label text="AO" styleClass="avatar-text" /></StackPane>
                <VBox spacing="2" HBox.hgrow="ALWAYS"><Label text="Alex Owens" styleClass="profile-name" /><Label text="Librarian" styleClass="profile-role" /></VBox>
                <Button text="↪" styleClass="icon-button-quiet" onAction="#showPlaceholder" />
            </HBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="22" styleClass="holds-content">
            <HBox alignment="CENTER_LEFT" spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS"><Label text="Holds" styleClass="page-title" /><Label text="Manage book requests and queue positions." styleClass="page-subtitle" /></VBox>
                <Button text="+  Place hold" styleClass="primary-button" onAction="#showPlaceholder" />
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="holds-toolbar">
                <TextField promptText="Search by hold, member, or copy ID" HBox.hgrow="ALWAYS" styleClass="holds-search" />
                <ComboBox promptText="All statuses" prefWidth="160" styleClass="hold-filter" />
                <Button text="Clear filters" styleClass="toolbar-button" onAction="#showPlaceholder" />
            </HBox>

            <VBox spacing="0" VBox.vgrow="ALWAYS" styleClass="holds-panel">
                <HBox alignment="CENTER_LEFT" styleClass="holds-panel-header">
                    <VBox spacing="3" HBox.hgrow="ALWAYS"><Label text="Hold queue" styleClass="section-title" /><Label text="Active, fulfilled, and cancelled requests" styleClass="section-subtitle" /></VBox>
                    <Label text="Showing 1–5 of 126" styleClass="result-count" />
                </HBox>

                <GridPane styleClass="hold-table-header">
                    <columnConstraints><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="17" /><ColumnConstraints percentWidth="17" /><ColumnConstraints percentWidth="12" /><ColumnConstraints percentWidth="12" /><ColumnConstraints percentWidth="16" /><ColumnConstraints percentWidth="12" /></columnConstraints>
                    <Label text="HOLD ID" styleClass="column-label" GridPane.columnIndex="0" /><Label text="MEMBER ID" styleClass="column-label" GridPane.columnIndex="1" /><Label text="COPY ID" styleClass="column-label" GridPane.columnIndex="2" /><Label text="QUEUE" styleClass="column-label" GridPane.columnIndex="3" /><Label text="STATUS" styleClass="column-label" GridPane.columnIndex="4" /><Label text="EXPIRES" styleClass="column-label" GridPane.columnIndex="5" /><Label text="ACTIONS" styleClass="column-label" GridPane.columnIndex="6" />
                </GridPane>

                <VBox spacing="0" VBox.vgrow="ALWAYS">
                    <GridPane alignment="CENTER_LEFT" styleClass="hold-row"><columnConstraints><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="17" /><ColumnConstraints percentWidth="17" /><ColumnConstraints percentWidth="12" /><ColumnConstraints percentWidth="12" /><ColumnConstraints percentWidth="16" /><ColumnConstraints percentWidth="12" /></columnConstraints><Label text="H-5012" styleClass="hold-id" GridPane.columnIndex="0" /><Label text="U-10428" styleClass="cell-text" GridPane.columnIndex="1" /><Label text="CP-8338" styleClass="cell-text" GridPane.columnIndex="2" /><Label text="#1" styleClass="queue-badge" GridPane.columnIndex="3" /><Label text="Active" styleClass="status-active" GridPane.columnIndex="4" /><Label text="Jul 24, 2026" styleClass="cell-text" GridPane.columnIndex="5" /><HBox spacing="6" GridPane.columnIndex="6"><Button text="Edit" styleClass="row-action" onAction="#showPlaceholder" /><Button text="Cancel" styleClass="row-delete" onAction="#showPlaceholder" /></HBox></GridPane>
                    <GridPane alignment="CENTER_LEFT" styleClass="hold-row"><columnConstraints><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="17" /><ColumnConstraints percentWidth="17" /><ColumnConstraints percentWidth="12" /><ColumnConstraints percentWidth="12" /><ColumnConstraints percentWidth="16" /><ColumnConstraints percentWidth="12" /></columnConstraints><Label text="H-5013" styleClass="hold-id" GridPane.columnIndex="0" /><Label text="U-10431" styleClass="cell-text" GridPane.columnIndex="1" /><Label text="CP-8340" styleClass="cell-text" GridPane.columnIndex="2" /><Label text="#2" styleClass="queue-badge" GridPane.columnIndex="3" /><Label text="Active" styleClass="status-active" GridPane.columnIndex="4" /><Label text="Jul 25, 2026" styleClass="cell-text" GridPane.columnIndex="5" /><HBox spacing="6" GridPane.columnIndex="6"><Button text="Edit" styleClass="row-action" onAction="#showPlaceholder" /><Button text="Cancel" styleClass="row-delete" onAction="#showPlaceholder" /></HBox></GridPane>
                    <GridPane alignment="CENTER_LEFT" styleClass="hold-row"><columnConstraints><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="17" /><ColumnConstraints percentWidth="17" /><ColumnConstraints percentWidth="12" /><ColumnConstraints percentWidth="12" /><ColumnConstraints percentWidth="16" /><ColumnConstraints percentWidth="12" /></columnConstraints><Label text="H-5009" styleClass="hold-id" GridPane.columnIndex="0" /><Label text="U-10430" styleClass="cell-text" GridPane.columnIndex="1" /><Label text="CP-8324" styleClass="cell-text" GridPane.columnIndex="2" /><Label text="—" styleClass="cell-text" GridPane.columnIndex="3" /><Label text="Fulfilled" styleClass="status-fulfilled" GridPane.columnIndex="4" /><Label text="Jul 19, 2026" styleClass="cell-text" GridPane.columnIndex="5" /><HBox spacing="6" GridPane.columnIndex="6"><Button text="View" styleClass="row-action" onAction="#showPlaceholder" /></HBox></GridPane>
                    <GridPane alignment="CENTER_LEFT" styleClass="hold-row"><columnConstraints><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="17" /><ColumnConstraints percentWidth="17" /><ColumnConstraints percentWidth="12" /><ColumnConstraints percentWidth="12" /><ColumnConstraints percentWidth="16" /><ColumnConstraints percentWidth="12" /></columnConstraints><Label text="H-5008" styleClass="hold-id" GridPane.columnIndex="0" /><Label text="U-10429" styleClass="cell-text" GridPane.columnIndex="1" /><Label text="CP-8319" styleClass="cell-text" GridPane.columnIndex="2" /><Label text="—" styleClass="cell-text" GridPane.columnIndex="3" /><Label text="Cancelled" styleClass="status-cancelled" GridPane.columnIndex="4" /><Label text="Jul 18, 2026" styleClass="cell-text" GridPane.columnIndex="5" /><HBox spacing="6" GridPane.columnIndex="6"><Button text="View" styleClass="row-action" onAction="#showPlaceholder" /></HBox></GridPane>
                    <GridPane alignment="CENTER_LEFT" styleClass="hold-row, hold-row-last"><columnConstraints><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="17" /><ColumnConstraints percentWidth="17" /><ColumnConstraints percentWidth="12" /><ColumnConstraints percentWidth="12" /><ColumnConstraints percentWidth="16" /><ColumnConstraints percentWidth="12" /></columnConstraints><Label text="H-5014" styleClass="hold-id" GridPane.columnIndex="0" /><Label text="U-10432" styleClass="cell-text" GridPane.columnIndex="1" /><Label text="CP-8342" styleClass="cell-text" GridPane.columnIndex="2" /><Label text="#1" styleClass="queue-badge" GridPane.columnIndex="3" /><Label text="Active" styleClass="status-active" GridPane.columnIndex="4" /><Label text="Jul 27, 2026" styleClass="cell-text" GridPane.columnIndex="5" /><HBox spacing="6" GridPane.columnIndex="6"><Button text="Edit" styleClass="row-action" onAction="#showPlaceholder" /><Button text="Cancel" styleClass="row-delete" onAction="#showPlaceholder" /></HBox></GridPane>
                </VBox>

                <HBox alignment="CENTER_RIGHT" spacing="6" styleClass="pagination"><Button text="←" styleClass="page-button" onAction="#showPlaceholder" /><Button text="1" styleClass="page-button-active" onAction="#showPlaceholder" /><Button text="2" styleClass="page-button" onAction="#showPlaceholder" /><Button text="3" styleClass="page-button" onAction="#showPlaceholder" /><Button text="→" styleClass="page-button" onAction="#showPlaceholder" /></HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
