<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="ui.librarian.NavigationController" prefWidth="1440" prefHeight="900" styleClass="root-pane">
    <left>
        <VBox prefWidth="248" styleClass="sidebar">
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="brand-block"><StackPane styleClass="brand-mark"><Label text="L" styleClass="brand-mark-text" /></StackPane><VBox spacing="1"><Label text="Libris" styleClass="brand-title" /><Label text="LIBRARIAN PORTAL" styleClass="brand-caption" /></VBox></HBox>
            <Label text="WORKSPACE" styleClass="nav-section-label" />
            <VBox spacing="6" styleClass="nav-list"><Button text="⌂   Dashboard" maxWidth="Infinity" styleClass="nav-button" onAction="#showDashboard" /><Button text="▤   Books" maxWidth="Infinity" styleClass="nav-button" onAction="#showBooks" /><Button text="♙   Members" maxWidth="Infinity" styleClass="nav-button" onAction="#showMembers" /><Button text="⇄   Borrow &amp; Return" maxWidth="Infinity" styleClass="nav-button" onAction="#showBorrowReturn" /><Button text="◷   Holds" maxWidth="Infinity" styleClass="nav-button" onAction="#showHolds" /><Button text="\$   Fines" maxWidth="Infinity" styleClass="nav-button" onAction="#showFines" /></VBox>
            <Label text="MANAGEMENT" styleClass="nav-section-label" />
            <VBox spacing="6" styleClass="nav-list"><Button text="▦   Audit Log" maxWidth="Infinity" styleClass="nav-active" onAction="#showAuditLog" /><Button text="▥   Reports" maxWidth="Infinity" styleClass="nav-button" onAction="#showReports" /><Button text="⚙   Settings" maxWidth="Infinity" styleClass="nav-button" onAction="#showSettings" /></VBox>
            <Pane VBox.vgrow="ALWAYS" />
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-profile"><StackPane styleClass="avatar-small"><Label text="AO" styleClass="avatar-text" /></StackPane><VBox spacing="2" HBox.hgrow="ALWAYS"><Label text="Alex Owens" styleClass="profile-name" /><Label text="Librarian" styleClass="profile-role" /></VBox><Button text="↪" styleClass="icon-button-quiet" onAction="#showPlaceholder" /></HBox>
        </VBox>
    </left>

    <center>
        <VBox spacing="22" styleClass="audit-content">
            <HBox alignment="CENTER_LEFT" spacing="16"><VBox spacing="4" HBox.hgrow="ALWAYS"><Label text="Audit Log" styleClass="page-title" /><Label text="Review recorded changes and system activity." styleClass="page-subtitle" /></VBox><Button text="Export log" styleClass="primary-button" onAction="#showPlaceholder" /></HBox>
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="audit-toolbar"><TextField promptText="Search actions, records, or notes" HBox.hgrow="ALWAYS" styleClass="audit-search" /><ComboBox promptText="All actions" prefWidth="145" styleClass="audit-filter" /><ComboBox promptText="All record types" prefWidth="165" styleClass="audit-filter" /><DatePicker promptText="Select date" prefWidth="150" styleClass="audit-filter" /><Button text="Clear" styleClass="toolbar-button" onAction="#showPlaceholder" /></HBox>

            <VBox spacing="0" VBox.vgrow="ALWAYS" styleClass="audit-panel">
                <HBox alignment="CENTER_LEFT" styleClass="audit-panel-header"><VBox spacing="3" HBox.hgrow="ALWAYS"><Label text="System activity" styleClass="section-title" /><Label text="Entries are permanent and cannot be edited" styleClass="section-subtitle" /></VBox><Label text="Showing 1–5 of 1,294" styleClass="result-count" /></HBox>
                <GridPane styleClass="audit-table-header"><columnConstraints><ColumnConstraints percentWidth="11" /><ColumnConstraints percentWidth="13" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="13" /><ColumnConstraints percentWidth="25" /><ColumnConstraints percentWidth="10" /></columnConstraints><Label text="LOG ID" styleClass="column-label" GridPane.columnIndex="0" /><Label text="USER ID" styleClass="column-label" GridPane.columnIndex="1" /><Label text="ACTION" styleClass="column-label" GridPane.columnIndex="2" /><Label text="RECORD TYPE" styleClass="column-label" GridPane.columnIndex="3" /><Label text="RECORD ID" styleClass="column-label" GridPane.columnIndex="4" /><Label text="NOTES" styleClass="column-label" GridPane.columnIndex="5" /><Label text="DATE" styleClass="column-label" GridPane.columnIndex="6" /></GridPane>
                <VBox spacing="0" VBox.vgrow="ALWAYS">
                    <GridPane styleClass="audit-row"><columnConstraints><ColumnConstraints percentWidth="11" /><ColumnConstraints percentWidth="13" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="13" /><ColumnConstraints percentWidth="25" /><ColumnConstraints percentWidth="10" /></columnConstraints><Label text="L-8421" styleClass="log-id" GridPane.columnIndex="0" /><Label text="U-10001" styleClass="cell-text" GridPane.columnIndex="1" /><Label text="Updated" styleClass="action-update" GridPane.columnIndex="2" /><Label text="Book" styleClass="cell-text" GridPane.columnIndex="3" /><Label text="T-1042" styleClass="cell-text" GridPane.columnIndex="4" /><Label text="Updated title availability" styleClass="note-text" GridPane.columnIndex="5" /><Label text="Jul 17" styleClass="cell-text" GridPane.columnIndex="6" /></GridPane>
                    <GridPane styleClass="audit-row"><columnConstraints><ColumnConstraints percentWidth="11" /><ColumnConstraints percentWidth="13" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="13" /><ColumnConstraints percentWidth="25" /><ColumnConstraints percentWidth="10" /></columnConstraints><Label text="L-8420" styleClass="log-id" GridPane.columnIndex="0" /><Label text="U-10001" styleClass="cell-text" GridPane.columnIndex="1" /><Label text="Created" styleClass="action-create" GridPane.columnIndex="2" /><Label text="Checkout" styleClass="cell-text" GridPane.columnIndex="3" /><Label text="C-2841" styleClass="cell-text" GridPane.columnIndex="4" /><Label text="Book checked out to member" styleClass="note-text" GridPane.columnIndex="5" /><Label text="Jul 17" styleClass="cell-text" GridPane.columnIndex="6" /></GridPane>
                    <GridPane styleClass="audit-row"><columnConstraints><ColumnConstraints percentWidth="11" /><ColumnConstraints percentWidth="13" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="13" /><ColumnConstraints percentWidth="25" /><ColumnConstraints percentWidth="10" /></columnConstraints><Label text="L-8419" styleClass="log-id" GridPane.columnIndex="0" /><Label text="U-10001" styleClass="cell-text" GridPane.columnIndex="1" /><Label text="Created" styleClass="action-create" GridPane.columnIndex="2" /><Label text="Member" styleClass="cell-text" GridPane.columnIndex="3" /><Label text="U-10432" styleClass="cell-text" GridPane.columnIndex="4" /><Label text="New member account created" styleClass="note-text" GridPane.columnIndex="5" /><Label text="Jul 17" styleClass="cell-text" GridPane.columnIndex="6" /></GridPane>
                    <GridPane styleClass="audit-row"><columnConstraints><ColumnConstraints percentWidth="11" /><ColumnConstraints percentWidth="13" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="13" /><ColumnConstraints percentWidth="25" /><ColumnConstraints percentWidth="10" /></columnConstraints><Label text="L-8418" styleClass="log-id" GridPane.columnIndex="0" /><Label text="U-10001" styleClass="cell-text" GridPane.columnIndex="1" /><Label text="Updated" styleClass="action-update" GridPane.columnIndex="2" /><Label text="Fine" styleClass="cell-text" GridPane.columnIndex="3" /><Label text="F-2930" styleClass="cell-text" GridPane.columnIndex="4" /><Label text="Fine marked as paid" styleClass="note-text" GridPane.columnIndex="5" /><Label text="Jul 16" styleClass="cell-text" GridPane.columnIndex="6" /></GridPane>
                    <GridPane styleClass="audit-row, audit-row-last"><columnConstraints><ColumnConstraints percentWidth="11" /><ColumnConstraints percentWidth="13" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="14" /><ColumnConstraints percentWidth="13" /><ColumnConstraints percentWidth="25" /><ColumnConstraints percentWidth="10" /></columnConstraints><Label text="L-8417" styleClass="log-id" GridPane.columnIndex="0" /><Label text="U-10001" styleClass="cell-text" GridPane.columnIndex="1" /><Label text="Cancelled" styleClass="action-delete" GridPane.columnIndex="2" /><Label text="Hold" styleClass="cell-text" GridPane.columnIndex="3" /><Label text="H-5008" styleClass="cell-text" GridPane.columnIndex="4" /><Label text="Member cancelled hold" styleClass="note-text" GridPane.columnIndex="5" /><Label text="Jul 16" styleClass="cell-text" GridPane.columnIndex="6" /></GridPane>
                </VBox>
                <HBox alignment="CENTER_RIGHT" spacing="6" styleClass="pagination"><Button text="←" styleClass="page-button" onAction="#showPlaceholder" /><Button text="1" styleClass="page-button-active" onAction="#showPlaceholder" /><Button text="2" styleClass="page-button" onAction="#showPlaceholder" /><Button text="3" styleClass="page-button" onAction="#showPlaceholder" /><Button text="→" styleClass="page-button" onAction="#showPlaceholder" /></HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
