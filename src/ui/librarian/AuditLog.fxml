<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?><?import javafx.scene.control.*?><?import javafx.scene.layout.*?>
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ui.librarian.AuditLogController" prefWidth="1440" prefHeight="900" styleClass="root-pane">
<left><VBox prefWidth="248" styleClass="sidebar"><HBox alignment="CENTER_LEFT" spacing="12" styleClass="brand-block"><StackPane styleClass="brand-mark"><Label text="L" styleClass="brand-mark-text"/></StackPane><VBox spacing="1"><Label text="Libris" styleClass="brand-title"/><Label text="LIBRARIAN PORTAL" styleClass="brand-caption"/></VBox></HBox><Label text="WORKSPACE" styleClass="nav-section-label"/><VBox spacing="6" styleClass="nav-list"><Button text="⌂   Dashboard" maxWidth="Infinity" styleClass="nav-button" onAction="#showDashboard"/><Button text="▤   Books" maxWidth="Infinity" styleClass="nav-button" onAction="#showBooks"/><Button text="♙   Members" maxWidth="Infinity" styleClass="nav-button" onAction="#showMembers"/><Button text="⇄   Borrow &amp; Return" maxWidth="Infinity" styleClass="nav-button" onAction="#showBorrowReturn"/><Button text="◷   Holds" maxWidth="Infinity" styleClass="nav-button" onAction="#showHolds"/><Button text="\$   Fines" maxWidth="Infinity" styleClass="nav-button" onAction="#showFines"/></VBox><Label text="MANAGEMENT" styleClass="nav-section-label"><VBox.margin><Insets top="20"/></VBox.margin></Label><VBox spacing="6" styleClass="nav-list"><Button text="▦   Audit Log" maxWidth="Infinity" styleClass="nav-active" onAction="#showAuditLog"/><Button text="▥   Reports" maxWidth="Infinity" styleClass="nav-button" onAction="#showReports"/><Button text="⚙   Settings" maxWidth="Infinity" styleClass="nav-button" onAction="#showSettings"/></VBox><Pane VBox.vgrow="ALWAYS"/><HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-profile"><StackPane styleClass="avatar-small"><Label fx:id="sidebarProfileInitials" text="L" styleClass="avatar-text"/></StackPane><VBox spacing="2" HBox.hgrow="ALWAYS"><Label fx:id="sidebarProfileName" text="Signed-in librarian" styleClass="profile-name"/><Label text="Librarian" styleClass="profile-role"/></VBox><Button text="↪" styleClass="icon-button-quiet" onAction="#showLogin"/></HBox></VBox></left>
<center><VBox spacing="22" styleClass="audit-content"><HBox alignment="CENTER_LEFT"><VBox spacing="4" HBox.hgrow="ALWAYS"><Label text="Audit Log" styleClass="page-title"/><Label text="Review permanent activity recorded in the local library database." styleClass="page-subtitle"/></VBox><Button text="Refresh" styleClass="secondary-button" onAction="#refresh"/></HBox><VBox spacing="0" VBox.vgrow="ALWAYS" styleClass="audit-panel"><HBox alignment="CENTER_LEFT" styleClass="audit-panel-header"><VBox spacing="3" HBox.hgrow="ALWAYS"><Label text="System activity" styleClass="section-title"/><Label text="Entries cannot be edited or deleted." styleClass="section-subtitle"/></VBox><Label fx:id="count" text="Loading activity…" styleClass="result-count"/></HBox><TableView fx:id="table" VBox.vgrow="ALWAYS" styleClass="audit-table"><columns><TableColumn fx:id="idCol" text="LOG ID" prefWidth="130"/><TableColumn fx:id="userCol" text="USER" prefWidth="170"/><TableColumn fx:id="actionCol" text="ACTION" prefWidth="125"/><TableColumn fx:id="typeCol" text="RECORD TYPE" prefWidth="135"/><TableColumn fx:id="recordCol" text="RECORD ID" prefWidth="145"/><TableColumn fx:id="notesCol" text="NOTES" prefWidth="300"/><TableColumn fx:id="dateCol" text="DATE" prefWidth="145"/></columns><placeholder><Label text="No system activity has been recorded yet." styleClass="section-subtitle"/></placeholder></TableView></VBox></VBox></center>
</BorderPane>
